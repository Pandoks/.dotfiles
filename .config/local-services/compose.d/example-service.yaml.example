services:
  tailscale:
    container_name: my-service-tailscale
    image: tailscale/tailscale:latest
    hostname: my-service
    environment:
      - TS_STATE_DIR=/var/lib/tailscale
      - TS_SERVE_CONFIG=/config/serve.json
      - TS_USERSPACE=true
    env_file:
      - /Users/pandoks/.config/local-services/.env
    volumes:
      - tailscale-state:/var/lib/tailscale
    configs:
      - source: tailscale-serve
        target: /config/serve.json
    # "no" so only start-local-services.sh brings it up, never the daemon on its own startup.
    restart: "no"

configs:
  tailscale-serve:
    content: |
      {
        "TCP": {
          "443": {
            "HTTPS": true
          }
        },
        "Web": {
          "my-service.<tailnet>.ts.net:443": {
            "Handlers": {
              "/": {
                "Proxy": "http://host.docker.internal:<host-port>"
              }
            }
          }
        }
      }

volumes:
  tailscale-state:
